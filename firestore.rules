rules_version = '2';
service cloud.firestore {
match /databases/{database}/documents {

    // 1. Global Default-Deny Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Hardened Access Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedUser() {
      return isSignedIn() && (
        request.auth.token.email_verified == true || 
        request.auth.token.firebase.sign_in_provider == 'google.com'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'abhavanishankar989@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 3. Collection Rule Blocks

    // VEHICLES
    match /vehicles/{vehicleId} {
      allow read: if true;
      allow create, update, delete: if true; // Matches the original permissive structure
    }

    // BRANDS
    match /brands/{brandId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    // CATEGORIES
    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    // REVIEWS
    match /reviews/{reviewId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    // RESERVATIONS / BOOKINGS
    match /reservations/{reservationId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    // USERS
    match /users/{userId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    // VEHICLE COLORS
    match /vehicle_colors/{colorId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    // VEHICLE WHEELS
    match /vehicle_wheels/{wheelId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    // VEHICLE INTERIORS
    match /vehicle_interiors/{interiorId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    // VEHICLE PACKAGES
    match /vehicle_packages/{packageId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    // VEHICLE IMAGES
    match /vehicle_images/{imageId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    // VEHICLE CONFIGURATIONS (Saves selected configuration)
    match /vehicle_configurations/{configId} {
      allow read, write: if true;
    }

    // COMPARISON HISTORY
    match /comparison_history/{historyId} {
      allow read, write: if true;
    }

    // FAVORITES
    match /favorites/{favoriteId} {
      allow read, write: if true;
    }
  }
}
