{
  "entities": {
    "Vehicle": {
      "title": "Vehicle",
      "description": "High-fidelity vehicle representation covering multiple categories and specs",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier of the vehicle" },
        "name": { "type": "string", "description": "Display name of the vehicle" },
        "brand": { "type": "string", "description": "Brand or manufacturer name" },
        "model": { "type": "string", "description": "Specific vehicle model" },
        "year": { "type": "integer", "description": "Manufacturing year" },
        "category": { "type": "string", "description": "Category ID reference (e.g. SUV, Electric, Agricultural)" },
        "engine_type": { "type": "string", "description": "Combustion or electric configuration" },
        "fuel_type": { "type": "string", "description": "Electric, Hybrid, Gasoline, Diesel, Hydrogen" },
        "transmission": { "type": "string", "description": "Manual, Automatic, Single-Speed" },
        "horsepower": { "type": "integer", "description": "Peak horsepower output" },
        "torque": { "type": "integer", "description": "Torque in lb-ft" },
        "mileage": { "type": "integer", "description": "Mileage or efficiency rating details" },
        "battery_capacity": { "type": "string", "description": "Battery capacity if electric/hybrid" },
        "seating_capacity": { "type": "integer", "description": "Passenger capacity" },
        "dimensions": { "type": "string", "description": "L x W x H physical dimensions" },
        "weight": { "type": "integer", "description": "Dry weight in lbs" },
        "top_speed": { "type": "integer", "description": "Top speed in MPH" },
        "price": { "type": "integer", "description": "Base pricing" },
        "description": { "type": "string", "description": "Stylistic or sales description" },
        "specifications": { "type": "object", "description": "Full technical specifications array/mappings" },
        "image": { "type": "string", "description": "Main default vehicle image URL" },
        "images": { "type": "array", "description": "List of URLs to high-quality vehicle images" },
        "videos": { "type": "array", "description": "List of links to video walks" },
        "created_at": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "updated_at": { "type": "string", "format": "date-time", "description": "Last update timestamp" }
      },
      "required": ["id", "name", "brand", "model", "year", "category", "price", "description"]
    },
    "Brand": {
      "title": "Brand",
      "description": "Manufacturer entity containing country, established year, and assets",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier of the brand" },
        "brand_name": { "type": "string", "description": "Official name of the brand" },
        "country": { "type": "string", "description": "Origin country" },
        "founded_year": { "type": "integer", "description": "Year of foundation" },
        "logo": { "type": "string", "description": "URL to brand representation logo mark" },
        "website": { "type": "string", "description": "Brand website URL" }
      },
      "required": ["id", "brand_name", "country", "founded_year"]
    },
    "Category": {
      "title": "Category",
      "description": "Vehicle classification taxonomy",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique taxonomy identifier" },
        "category_name": { "type": "string", "description": "Explicit title of the category (e.g. Trucks, SUVs)" },
        "description": { "type": "string", "description": "Category application description" }
      },
      "required": ["id", "category_name"]
    },
    "Review": {
      "title": "Review",
      "description": "User reviews and star ratings linked to a vehicle",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique review identifier" },
        "vehicle_id": { "type": "string", "description": "Reference ID to the Vehicles collection" },
        "rating": { "type": "integer", "description": "Star rating out of 5" },
        "review": { "type": "string", "description": "Explicit text block review content" },
        "author": { "type": "string", "description": "Name or handle of reviewing author" },
        "created_at": { "type": "string", "format": "date-time", "description": "Date of publication" }
      },
      "required": ["id", "vehicle_id", "rating", "review", "author"]
    },
    "User": {
      "title": "User",
      "description": "Registered and authenticated platform user record",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "User UID matching Firebase Auth provider" },
        "name": { "type": "string", "description": "User display name" },
        "email": { "type": "string", "description": "Primary authenticating email" },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User access level" }
      },
      "required": ["id", "name", "email", "role"]
    },
    "VehicleColor": {
      "title": "VehicleColor",
      "description": "Available metallic/satin paint formulas per vehicle",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique paint identification key" },
        "vehicleId": { "type": "string", "description": "Associated vehicle document key" },
        "name": { "type": "string", "description": "Paint style name" },
        "hex": { "type": "string", "description": "Color hex code" },
        "price": { "type": "integer", "description": "Pricing option cost" },
        "previewColor": { "type": "string", "description": "Simplified preview classification name" }
      },
      "required": ["id", "vehicleId", "name", "hex", "price"]
    },
    "VehicleWheel": {
      "title": "VehicleWheel",
      "description": "Available magnesium/alloy wheel designs per vehicle",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique wheel key" },
        "vehicleId": { "type": "string", "description": "Associated vehicle key" },
        "name": { "type": "string", "description": "Performance styling description" },
        "price": { "type": "integer", "description": "Incremental cost" },
        "previewUrl": { "type": "string", "description": "Preview class/URL string" }
      },
      "required": ["id", "vehicleId", "name", "price"]
    },
    "VehicleInterior": {
      "title": "VehicleInterior",
      "description": "Available lounge leather configurations per vehicle",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique interior design key" },
        "vehicleId": { "type": "string", "description": "Associated vehicle key" },
        "name": { "type": "string", "description": "Interior design styling name" },
        "price": { "type": "integer", "description": "Incremental interior package cost" }
      },
      "required": ["id", "vehicleId", "name", "price"]
    },
    "VehiclePackage": {
      "title": "VehiclePackage",
      "description": "Luxury performance/autonomous tech upgrades",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique upgrade key" },
        "vehicleId": { "type": "string", "description": "Associated vehicle key" },
        "name": { "type": "string", "description": "Name of the optional package" },
        "description": { "type": "string", "description": "Performance specs details description" },
        "price": { "type": "integer", "description": "Upgrade premium surcharge" }
      },
      "required": ["id", "vehicleId", "name", "description", "price"]
    },
    "VehicleImage": {
      "title": "VehicleImage",
      "description": "Specific variant and high-res perspective image routes",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique asset key" },
        "vehicleId": { "type": "string", "description": "Associated vehicle key" },
        "colorId": { "type": "string", "description": "Optional color paint identification key reference" },
        "imageUrl": { "type": "string", "description": "High resolution full perspective rendering image URL" },
        "thumbnailUrl": { "type": "string", "description": "Compact thumbnail rendering URL" }
      },
      "required": ["id", "vehicleId", "imageUrl"]
    },
    "VehicleConfiguration": {
      "title": "VehicleConfiguration",
      "description": "Record tracking currently saved active custom configurations for client profiles",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Configuration ticket serial id" },
        "userId": { "type": "string", "description": "Creator UID, supports guest strings" },
        "vehicleId": { "type": "string", "description": "Vehicle outline reference" },
        "colorId": { "type": "string", "description": "Selected color id" },
        "wheelId": { "type": "string", "description": "Selected wheel id" },
        "interiorId": { "type": "string", "description": "Selected interior id" },
        "packageIds": { "type": "array", "description": "List of active surcharge options package IDs" },
        "totalPrice": { "type": "integer", "description": "Total checkout price" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "State modification tick" }
      },
      "required": ["id", "userId", "vehicleId", "colorId", "wheelId", "totalPrice"]
    },
    "ComparisonHistory": {
      "title": "ComparisonHistory",
      "description": "Historic comparison event audit records",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Comparison ticket key" },
        "userId": { "type": "string", "description": "Client auditor UID" },
        "comparedVehicleIds": { "type": "array", "description": "Array of vehicle unique keys" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Audit tick" }
      },
      "required": ["id", "userId", "comparedVehicleIds", "timestamp"]
    },
    "Favorite": {
      "title": "Favorite",
      "description": "Shortlisted vehicle tracking cards",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Composite UID-VehicleID key" },
        "userId": { "type": "string", "description": "Client holder key" },
        "vehicleId": { "type": "string", "description": "Faved vehicle key" }
      },
      "required": ["id", "userId", "vehicleId"]
    }
  },
  "firestore": {
    "vehicles": {
      "schema": { "$ref": "#/definitions/Vehicle" },
      "description": "Storage collection for all registered vehicles"
    },
    "brands": {
      "schema": { "$ref": "#/definitions/Brand" },
      "description": "Storage collection for global vehicle brands"
    },
    "categories": {
      "schema": { "$ref": "#/definitions/Category" },
      "description": "Storage collection for taxonomical vehicle classifications"
    },
    "reviews": {
      "schema": { "$ref": "#/definitions/Review" },
      "description": "Client feedback and reviews referencing specific vehicle docs"
    },
    "users": {
      "schema": { "$ref": "#/definitions/User" },
      "description": "User profiles synchronizing credentials with role authorizations"
    },
    "vehicle_colors": {
      "schema": { "$ref": "#/definitions/VehicleColor" },
      "description": "Colors customization catalogue list mapping styles and variant prices"
    },
    "vehicle_wheels": {
      "schema": { "$ref": "#/definitions/VehicleWheel" },
      "description": "Wheel customization catalog lists mapping wheel options and surcharge margins"
    },
    "vehicle_interiors": {
      "schema": { "$ref": "#/definitions/VehicleInterior" },
      "description": "Luxury custom materials and trim options"
    },
    "vehicle_packages": {
      "schema": { "$ref": "#/definitions/VehiclePackage" },
      "description": "Tech options and premium upgrade packages catalog"
    },
    "vehicle_images": {
      "schema": { "$ref": "#/definitions/VehicleImage" },
      "description": "Dynamic variant image mapping database"
    },
    "vehicle_configurations": {
      "schema": { "$ref": "#/definitions/VehicleConfiguration" },
      "description": "Historic and active configurations persisted state lists"
    },
    "comparison_history": {
      "schema": { "$ref": "#/definitions/ComparisonHistory" },
      "description": "Manual client vehicle audit listings"
    },
    "favorites": {
      "schema": { "$ref": "#/definitions/Favorite" },
      "description": "Vehicle client shortlist markers"
    }
  }
}
